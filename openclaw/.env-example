# OpenClaw environment configuration
# Documentation: https://docs.openclaw.ai/install/docker

# Gateway authentication token. Generate one with:
#   openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=<your-gateway-token>

# --- Model Providers ---
# Configure one or more providers below. You can use cloud providers,
# local models via Ollama, or both.

# Cloud Providers (requires an API subscription)
ANTHROPIC_API_KEY=<your-anthropic-api-key>
# OPENAI_API_KEY=<your-openai-api-key>
# GEMINI_API_KEY=<your-gemini-api-key>
# OPENROUTER_API_KEY=<your-openrouter-api-key>

# Local Models via Ollama (requires the ollama/ service to be running)
# See ../ollama/README.md to set up Ollama first.
# OLLAMA_API_KEY=ollama-local
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# Docker image to use. Set to "openclaw:local" if building from source
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Gateway bind mode: "lan" (accessible on local network) or "localhost" (local only)
OPENCLAW_GATEWAY_BIND=lan

# The values below this line do not need to be changed
###################################################################################

# Host directories mounted into the container (relative to this file)
OPENCLAW_CONFIG_DIR=./config
OPENCLAW_WORKSPACE_DIR=./workspace
