# OpenClaw environment configuration
# Documentation: https://docs.openclaw.ai/install/docker

# Gateway authentication token. Generate one with:
#   openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=<your-gateway-token>

# --- Model Providers ---
# Configure one or more providers below. You can use cloud providers,
# local models via Ollama, or both.

# Cloud Providers (requires an API subscription)
ANTHROPIC_API_KEY=<your-anthropic-api-key>
# Optional: override TypeAgent memory plugin to use OpenAI instead of local Ollama
# OPENAI_API_KEY=<your-openai-api-key>
# GEMINI_API_KEY=<your-gemini-api-key>
# OPENROUTER_API_KEY=<your-openrouter-api-key>

# WhatsApp channel — your phone number in E.164 format (e.g. +12065551234)
# Only this number will be allowed to DM the agent.
WHATSAPP_ALLOW_FROM=<your-phone-number>

# Local Models via Ollama (requires an Ollama server to be running).
# On macOS, run Ollama natively (do not use the Docker-based Ollama setup). On other
# platforms, you may use a native install or the ollama/docker-compose.yml setup where supported.
# See the "Local Models (Ollama)" section in the main README / docs for up-to-date guidance.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=ollama-local
OLLAMA_MODEL=qwen3.5:9b

# Docker image to use. Set to "openclaw:local" if building from source
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Gateway bind mode: "lan" (accessible on local network) or "localhost" (local only)
OPENCLAW_GATEWAY_BIND=lan

# The values below this line do not need to be changed
###################################################################################

# Host directories mounted into the container (relative to this file)
OPENCLAW_CONFIG_DIR=./config
OPENCLAW_WORKSPACE_DIR=./workspace
OPENCLAW_EXTENSIONS_DIR=./extensions
TYPEAGENT_DIR=../typeagent
