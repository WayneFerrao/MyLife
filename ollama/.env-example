# Ollama environment configuration
# Documentation: https://github.com/ollama/ollama/blob/main/docs/faq.md

# Bind address inside the container (no need to change)
OLLAMA_HOST=0.0.0.0:11434

# --- Performance Tuning (optional) ---
# Enable flash attention (reduces memory usage, improves speed)
OLLAMA_FLASH_ATTENTION=1

# Quantize KV cache to reduce VRAM usage (~50% savings)
OLLAMA_KV_CACHE_TYPE=q8_0

# Context window size in tokens (higher = more memory)
# OLLAMA_NUM_CTX=24576
