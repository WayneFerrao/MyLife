# Root environment — controls which optional services start.
# Most configuration lives in per-service .env files (rag/.env, openclaw/.env, etc.)

# ── Service profiles ──────────────────────────────────────────────────
# Comma-separated list of optional services to enable.
# Options: ollama, immich
# Examples:
#   COMPOSE_PROFILES=              (core only: qdrant, rag, openclaw)
#   COMPOSE_PROFILES=immich        (core + photo management)
#   COMPOSE_PROFILES=ollama,immich (core + Docker-based Ollama + photos)
COMPOSE_PROFILES=

# ── Qdrant API key (optional) ────────────────────────────────────────
# When set, Qdrant requires this key on all requests (including dashboard).
# Generated by setup.sh. Must match QDRANT_API_KEY in rag/.env.
# QDRANT_API_KEY=

# ── OpenClaw overrides ────────────────────────────────────────────────
# OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
# OPENCLAW_CONFIG_DIR=./openclaw/config
# OPENCLAW_WORKSPACE_DIR=./openclaw/workspace
# OPENCLAW_EXTENSIONS_DIR=./openclaw/extensions

# ── Immich overrides (only used when immich profile is enabled) ───────
# IMMICH_VERSION=release
# UPLOAD_LOCATION=./immich/library
# DB_DATA_LOCATION=./immich/postgres
# DB_PASSWORD=changeme
# DB_USERNAME=postgres
# DB_DATABASE_NAME=immich
