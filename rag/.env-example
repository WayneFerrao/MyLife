# RAG Service environment configuration
# Documentation: See README.md

# Shared API key for authentication between OpenClaw and RAG service.
# Generate one with: openssl rand -hex 32
RAG_API_KEY=<your-rag-api-key>

# Ollama connection (used when EMBED_PROVIDER or CHAT_PROVIDER is "ollama")
OLLAMA_URL=http://host.docker.internal:11434

# Qdrant connection (vector database)
# Uses Docker service name since both RAG and Qdrant run on the same network.
# Use host.docker.internal:6333 only if Qdrant runs outside Docker.
QDRANT_URL=http://qdrant:6333

# Optional — Qdrant API key for authenticated access. Must match the
# service.api_key value in Qdrant's config. Leave empty to skip auth.
# QDRANT_API_KEY=

# ── Embedding provider ────────────────────────────────────────────────
# "ollama" = local Ollama (default)
# "openai" = any OpenAI-compatible API (OpenAI, Gemini, Mistral, etc.)
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text

# Uncomment for cloud embeddings (EMBED_PROVIDER=openai):
# EMBED_API_URL=https://api.openai.com/v1
# EMBED_API_KEY=sk-...
# EMBED_MODEL=text-embedding-3-small

# Embedding vector dimensions — must match the model set in EMBED_MODEL.
# Common values: nomic-embed-text=768, mxbai-embed-large=1024, all-minilm=384,
#   text-embedding-3-small=1536, text-embedding-3-large=3072
VECTOR_DIM=768

# nomic-embed-text requires task prefixes ("search_document:", "search_query:")
# for optimal retrieval. Most other embedding models do not use prefixes and
# quality may degrade if they're applied. Set to false for non-nomic models.
EMBED_PREFIX=true

# ── Chat provider (for metadata extraction) ──────────────────────────
# "ollama"    = local Ollama (default)
# "openai"    = any OpenAI-compatible API (OpenAI, Gemini, Mistral, Groq, etc.)
# "anthropic" = Anthropic Messages API (Claude)
CHAT_PROVIDER=ollama
CHAT_MODEL=qwen3.5:9b

# Uncomment for cloud chat (CHAT_PROVIDER=openai or anthropic):
# CHAT_API_URL=https://api.openai.com/v1
# CHAT_API_KEY=sk-...
# CHAT_MODEL=gpt-4o-mini

# ── Tuning ────────────────────────────────────────────────────────────

# Qdrant collection name
COLLECTION_NAME=notes

# Drop results below this cosine similarity score
# SCORE_THRESHOLD=0.3

# Timeout in seconds for upstream HTTP calls (Ollama, Qdrant). Increase if
# Ollama is slow to respond (e.g., first request while model is loading).
# HTTP_TIMEOUT=60

# Set to true to enable the /seed endpoint for loading test data
ALLOW_SEED=false
